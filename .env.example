# Шаблон переменных окружения для корневого docker-compose.
# Скопируй в .env  (cp .env.example .env)  перед `docker compose up`.
# Значения ниже — рабочие dev-дефолты «из коробки».
# ВАЖНО для прода: замени все секреты (POSTGRES_PASSWORD/DB_PASS, JWT_SECRET, SMTP).

# --- PostgreSQL (сервис postgres в compose) ---
POSTGRES_DB=transay
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Backend → подключение к БД ---
# Хост = имя сервиса postgres внутри compose-сети. Должно совпадать с POSTGRES_* выше:
#   DB_USER == POSTGRES_USER, DB_PASS == POSTGRES_PASSWORD, имя БД в URL == POSTGRES_DB.
DB_URL=jdbc:postgresql://postgres:5432/transay?rewriteBatchedInserts=true
DB_USER=postgres
DB_PASS=postgres

# --- Фронтенд (CORS + ссылки в письмах) ---
# Origin, с которого открывается приложение. Локально — порт фронт-контейнера (3000).
# На сервере — публичный домен, напр. https://transay.example.com
FRONT_URL=http://localhost:3000

# --- JWT ---
# ВАЖНО: base64-строка, декодирующаяся РОВНО в 32 байта (256 бит) → HS256.
# 48 байт дали бы HS384 и все защищённые запросы падали бы с 401. Для прода сгенерируй новый:
#   openssl rand -base64 32
JWT_SECRET=+OL4So2Qh5BOlAjWOffKLb1sDdQW3tRVhei3MhzzOOM=

# --- Почта (тестируемыми ручками не используется; заглушки нужны для резолва плейсхолдеров) ---
EMAIL_SERVER=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=noreply@example.com
EMAIL_PASSWORD=changeit
