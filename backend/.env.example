# Шаблон переменных окружения для docker compose.
# Скопируйте в .env (`cp .env.example .env`) перед `docker compose up`.
# Значения ниже — рабочие dev-дефолты для локального запуска «из коробки».
# Для реального деплоя замените секреты (JWT_SECRET, пароль БД, SMTP).

# --- База данных ---
# backend подключается к postgres по имени сервиса из docker-compose.yml
DB_URL=jdbc:postgresql://postgres:5432/transay?rewriteBatchedInserts=true
DB_USER=postgres
DB_PASS=postgres

# --- Фронтенд (CORS + ссылки в письмах) ---
FRONT_URL=http://localhost:3000

# --- JWT ---
# ВАЖНО: base64-строка, декодирующаяся РОВНО в 32 байта (256 бит).
# Тогда jjwt подписывает токен HS256 — совпадает с дефолтом NimbusJwtDecoder.
# 48 байт дали бы HS384 и все защищённые запросы падали бы с 401.
JWT_SECRET=+OL4So2Qh5BOlAjWOffKLb1sDdQW3tRVhei3MhzzOOM=

# --- Почта (для тестируемых ручок не используется; заглушки нужны для резолва плейсхолдеров) ---
EMAIL_SERVER=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=noreply@example.com
EMAIL_PASSWORD=changeit
