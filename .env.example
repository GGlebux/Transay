# Скопируй в .env. Для прода замени секреты. Подробности — в README.
POSTGRES_DB=transay
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# DB_USER/DB_PASS должны совпадать с POSTGRES_USER/POSTGRES_PASSWORD, имя БД в URL — с POSTGRES_DB
DB_URL=jdbc:postgresql://postgres:5432/transay?rewriteBatchedInserts=true
DB_USER=postgres
DB_PASS=postgres

FRONT_URL=http://localhost:3000

# base64, ровно 32 байта (HS256). Прод: openssl rand -base64 32
JWT_SECRET=+OL4So2Qh5BOlAjWOffKLb1sDdQW3tRVhei3MhzzOOM=

EMAIL_SERVER=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=noreply@example.com
EMAIL_PASSWORD=changeit
